# ── LLM Configuration ─────────────────────────────────────────────────────────
# intel-hub supports any LLM via LiteLLM (100+ providers).
# Set LLM_API_KEY / LLM_BASE_URL / LLM_MODEL, or use the legacy OPENAI_* names.

# ── Option 1: DeepSeek (recommended — R1 reasoning chain support) ──────────────
LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-reasoner

# ── Option 2: OpenAI ───────────────────────────────────────────────────────────
# LLM_API_KEY=sk-xxxxxxxxxxxxxxxx
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini

# ── Option 3: Anthropic Claude ────────────────────────────────────────────────
# LLM_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
# LLM_MODEL=anthropic/claude-3-5-sonnet-20241022
# (no LLM_BASE_URL needed for Anthropic)

# ── Option 4: Google Gemini ───────────────────────────────────────────────────
# LLM_API_KEY=xxxxxxxxxxxxxxxx
# LLM_MODEL=gemini/gemini-1.5-pro
# (no LLM_BASE_URL needed for Gemini)

# ── Option 5: Ollama (local) ──────────────────────────────────────────────────
# LLM_API_KEY=ollama
# LLM_BASE_URL=http://localhost:11434
# LLM_MODEL=ollama/llama3.1

# ── Option 6: Any OpenAI-compatible API ───────────────────────────────────────
# LLM_API_KEY=your-key
# LLM_BASE_URL=https://your-api-endpoint/v1
# LLM_MODEL=your-model-name

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=http://localhost:5173
